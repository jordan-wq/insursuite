# Comma-separated authenticated staff emails allowed to open the Agent Console.
AGENT_EMAILS=agent@example.com

# Supabase Auth. Add these in Vercel after creating a Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
INSURSUITE_REQUIRE_AUTH=true

# Optional future model-backed chatbot integration. The current retrieval bot
# does not call OpenAI and runs without this value.
OPENAI_API_KEY=replace_with_server_side_secret

# Documentation-only convenience value; production hosting supplies its URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
