# Supabase Auth. Add these in Vercel after creating a Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase now labels this value as the publishable key. Older projects may call it the anon public key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key
# Server-only. Bypasses RLS for the agent console -- never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
INSURSUITE_REQUIRE_AUTH=true

# Agent Console access is granted per-user via the agent_roles table, not an
# env var: insert a row into public.agent_roles(user_id) for each staff
# account (that user must sign up first).

# Optional future model-backed chatbot integration. The current retrieval bot
# does not call OpenAI and runs without this value.
OPENAI_API_KEY=replace_with_server_side_secret

# Documentation-only convenience value; production hosting supplies its URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
